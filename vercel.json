{
  "buildCommand": "npm run build",
  "functions": {
    "api/mcp.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/sse",
      "destination": "/api/sse"
    },
    {
      "source": "/messages",
      "destination": "/api/sse"
    },
    {
      "source": "/mcp-v2",
      "destination": "/api/mcp"
    },
    {
      "source": "/mcp",
      "destination": "/api/mcp"
    }
  ]
}
